# Copy this file to .env and fill in your values
# NEVER commit .env to source control

BASE_URL=

MAKER_USERNAME=
MAKER_PASSWORD=

CHECKER_USERNAME=
CHECKER_PASSWORD=

# Absolute path to the compiled JNLP runner JAR
# Default: ../../java-jnlp/target/jnlp-runner-1.0.jar
JNLP_JAR_PATH=

# Absolute path to the .jnlp file (usually in ~/Downloads)
JNLP_FILE_PATH=
